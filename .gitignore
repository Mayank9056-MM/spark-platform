packages/database/generated

# ── Logs ───────────────────────────────────
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Testing ────────────────────────────────
coverage
.nyc_output
playwright-report
playwright/.cache
test-results

# ── Editor / OS ────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────
